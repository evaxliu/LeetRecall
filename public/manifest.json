{
  "manifest_version": 3,
  "name": "LeetRecall",
  "version": "1.0.0",
  "description": "A Chrome extension that tracks Leetcode submissions and schedules smarter reviews for interview prep.",
  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost/*"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": [
        ""
      ],
      "css": [
        ""
      ]
    }
  ]
}